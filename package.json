{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "homepage": "https://github.com/jigneshkariya/terminator",
  "author": {
    "name": "Jignesh Kariya",
    "email": "india9898048483@gmail.com"
  },
  "description": "Matrix style terminal application",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "vite build",
    "start": "npx serve -s dist",
    "preview": "vite preview",
    "clean": "rm -rf dist server.js release",
    "lint": "tsc --noEmit",
    "electron:dev": "NODE_ENV=development electron .",
    "electron:build": "npm run build && electron-builder build --win --linux",
    "cap:sync": "npm run build && cap sync",
    "cap:add-android": "cap add android",
    "cap:open-android": "cap open android"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/cli": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "@google/genai": "^2.4.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "serve": "^14.2.4",
    "vite": "^6.2.3",
    "vite-plugin-pwa": "^1.3.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2"
  },
  "build": {
    "appId": "com.jignesh.terminator",
    "productName": "Terminator",
    "directories": {
      "output": "release"
    },
    "linux": {
      "target": ["deb"]
    }
  }
}